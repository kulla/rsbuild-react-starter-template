    "@tailwindcss/postcss": "^4.2.2",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "1.3.11",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
